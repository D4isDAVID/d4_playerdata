{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "diagnostics": {
    "enable": true,
    "disable": [
      "global-element",
      "spell-check",
      "no-unknown"
    ],
    "groupFileStatus": {
      "ambiguity": "Any",
      "await": "Any",
      "codestyle": "Any",
      "conventions": "Any",
      "duplicate": "Any",
      "global": "Any",
      "luadoc": "Any",
      "redefined": "Any",
      "strict": "Any",
      "strong": "Any",
      "type-check": "Any",
      "unbalanced": "Any",
      "unused": "Any"
    },
    "groupSeverity": {
      "ambiguity": "Error",
      "await": "Error",
      "codestyle": "Error",
      "conventions": "Error",
      "duplicate": "Error",
      "global": "Error",
      "luadoc": "Error",
      "redefined": "Error",
      "strict": "Error",
      "strong": "Error",
      "type-check": "Error",
      "unbalanced": "Error",
      "unused": "Error"
    }
  },
  "format": {
    "enable": true
  },
  "nameStyle": {
    "config": {
      "local_name_style": "camel_case",
      "function_param_name_style": [
        "camel_case",
        {
          "type": "ignore",
          "param": ["_"]
        }
      ],
      "function_name_style": "camel_case",
      "local_function_name_style": "camel_case",
      "table_field_name_style": "camel_case",
      "global_variable_name_style": "pascal_case",
      "module_name_style": "camel_case",
      "require_module_name_style": "camel_case",
      "class_name_style": "pascal_case",
      "const_variable_name_style": "upper_snake_case",
      "module_local_name_style": "camel_case"
    }
  },
  "runtime": {
    "fileEncoding": "utf8",
    "nonstandardSymbol": [
      "/**/",
      "`",
      "+=",
      "-=",
      "*=",
      "/=",
      "<<=",
      ">>=",
      "&=",
      "|=",
      "^="
    ],
    "version": "Lua 5.4"
  },
  "type": {
    "castNumberToInteger": false,
    "checkTableShape": true,
    "inferParamType": false,
    "weakNilCheck": false,
    "weakUnionCheck": false
  }
}
